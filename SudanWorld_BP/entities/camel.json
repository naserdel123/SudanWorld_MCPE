{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "sudan:camel",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "sudan:camel_baby": {
        "minecraft:is_baby": {},
        "minecraft:scale": {
          "value": 0.5
        },
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": ["wheat", "hay_block"],
          "grow_up": {
            "event": "sudan:ageable_grow_up",
            "target": "self"
          }
        }
      },
      "sudan:camel_adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/camel.json"
        },
        "minecraft:behavior.hurt_by_target": {
          "priority": 1
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 2,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "monster"
              },
              "max_dist": 10
            }
          ]
        }
      },
      "sudan:camel_tamed": {
        "minecraft:is_tamed": {},
        "minecraft:health": {
          "value": 20,
          "max": 20
        },
        "minecraft:movement": {
          "value": 0.15
        },
        "minecraft:rideable": {
          "seat_count": 2,
          "family_types": ["player"],
          "interact_text": "action.interact.ride.camel",
          "seats": [
            {
              "position": [0.0, 1.375, 0.0],
              "rotate_rider_by": "query.is_saddled ? -90 : 0"
            },
            {
              "position": [0.0, 1.375, -0.5],
              "rotate_rider_by": "query.is_saddled ? 90 : 0"
            }
          ]
        },
        "minecraft:inventory": {
          "inventory_size": 15,
          "container_type": "horse"
        },
        "minecraft:equippable": {
          "slots": [
            {
              "slot": 0,
              "item": "saddle",
              "accepted_items": ["saddle"]
            }
          ]
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["camel", "animal"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:collision_box": {
        "width": 1.7,
        "height": 2.375
      },
      "minecraft:health": {
        "value": 15,
        "max": 15
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.09
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:nameable": {},
      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.panic": {
        "priority": 1,
        "speed_multiplier": 1.2
      },
      "minecraft:behavior.mount_pathing": {
        "priority": 2,
        "speed_multiplier": 1.0,
        "target_dist": 0.0,
        "track_target": true
      },
      "minecraft:behavior.leap_at_target": {
        "priority": 4,
        "target_dist": 0.4
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 0.8
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 8
      },
      "minecraft:behavior.tempt": {
        "priority": 5,
        "speed_multiplier": 1.0,
        "items": ["wheat", "hay_block", "apple", "carrot", "golden_carrot", "golden_apple", "sudan:dates"]
      },
      "minecraft:behavior.follow_parent": {
        "priority": 6,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "attack_interval": 20,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "monster"
            },
            "max_dist": 10
          }
        ],
        "must_see": true
      },
      "minecraft:behavior.breed": {
        "priority": 3,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.move_towards_restriction": {
        "priority": 4,
        "speed_multiplier": 0.8
      },
      "minecraft:behavior.drink_milk": {
        "priority": 5
      },
      "minecraft:behavior.eat_block": {
        "priority": 6
      },
      "minecraft:behavior.random_fly": {
        "priority": 7,
        "xz_dist": 10,
        "y_dist": 7,
        "y_offset": 0
      },
      "minecraft:physics": {},
      "minecraft:pushable": {},
      "minecraft:conditional_bandwidth_optimization": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 95,
            "add": {
              "component_groups": ["sudan:camel_adult"]
            }
          },
          {
            "weight": 5,
            "add": {
              "component_groups": ["sudan:camel_baby"]
            }
          }
        ]
      },
      "sudan:ageable_grow_up": {
        "remove": {
          "component_groups": ["sudan:camel_baby"]
        },
        "add": {
          "component_groups": ["sudan:camel_adult"]
        }
      },
      "minecraft:on_tame": {
        "remove": {
          "component_groups": ["sudan:camel_adult"]
        },
        "add": {
          "component_groups": ["sudan:camel_tamed"]
        }
      }
    }
  }
}
