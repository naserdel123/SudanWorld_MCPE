{
  "format_version": "1.20.0",
  "minecraft:feature": {
    "description": {
      "identifier": "sudan:acacia_savanna_tree"
    },
    "components": {
      "minecraft:tree_feature": {
        "trunk": {
          "trunk_height": {
            "base": 4,
            "intervals": [2, 1]
          },
          "trunk_block": {
            "name": "minecraft:acacia_log",
            "states": {
              "old_log_type": "acacia"
            }
          }
        },
        "canopy": {
          "canopy_offset": {
            "min": -3,
            "max": 0
          },
          "variation_chance": {
            "numerator": 1,
            "denominator": 2
          },
          "leaf_block": {
            "name": "minecraft:acacia_leaves"
          }
        },
        "may_grow_on": ["minecraft:grass_block", "minecraft:dirt", "sudan:nile_mud"],
        "may_replace": ["minecraft:air", "minecraft:acacia_leaves"]
      }
    }
  }
}
